# Exemplo de .env para laboratório com IPs de cada PC
# Use o IP real da LAN de cada máquina e mantenha as mesmas portas em todos os PCs.

# --- CLIENT ---
IP_NORTE=172.16.103.14
IP_SUL=172.16.103.13
IP_LESTE=172.16.103.12
IP_OESTE=172.16.103.11

GATEWAY_TCP_CLIENT_PORT=8081

# --- NORTE ---
IP_NORTE=172.16.103.14
IP_SUL=172.16.103.13
IP_LESTE=172.16.103.12
IP_OESTE=172.16.103.11

